{
  "name": "market-pulse-pedagogy",
  "version": "1.0.0",
  "description": "Market Pulse & Pedagogy — Stock dashboard with AI features",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build:client": "vite build",
    "build": "rm -rf dist node_modules/typescript/tsbuildinfo && vite build && tsc",
    "start": "NODE_ENV=production node dist/server/index.js",
    "cf:preview": "npm run build && npx wrangler dev",
    "cf:deploy": "npm run build && npx wrangler deploy",
    "cf:d1:migrate": "npx wrangler d1 migrations apply market-pulse",
    "cf:d1:seed": "npx wrangler d1 execute market-pulse --file=./migrations/0001_init.sql"
  },
