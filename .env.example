# Groq — used by POST /api/chat (AI Research). Set on the server only; do not use VITE_*.
GROQ_API_KEY=your-groq-api-key-here
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
# Market Pulse & Pedagogy — Environment Variables
# Copy this file to .env for local development.
# In production, set these in your host's environment configuration.

# ─── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
# Used by: /api/eli5, /api/predict, /api/vectors, scrub tone classification
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────

# Server port
PORT=3000

# Custom SQLite database path (default: ./market_pulse.db next to package.json)
# Example persistent path: DATABASE_PATH=/data/market_pulse.db
DATABASE_PATH=

# Cloudflare account ID (optional)
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token (optional)
CLOUDFLARE_API_TOKEN=

# Cloudflare D1 database ID (optional)
CLOUDFLARE_D1_DB_ID=
