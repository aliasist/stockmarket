# Market Pulse & Pedagogy — Environment Variables
# Copy this file to .env for local development.
# On Railway, set these in the service's "Variables" tab.

# ─── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
# Used by: /api/eli5, /api/predict, /api/vectors, scrub tone classification
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────

# Server port (Railway sets this automatically)
PORT=3000

# Custom SQLite database path (default: ./market_pulse.db next to package.json)
# On Railway with a volume: DATABASE_PATH=/data/market_pulse.db
DATABASE_PATH=

# Cloudflare API token (for CDN/Workers features — optional)
CLOUDFLARE_API_TOKEN=

# Supabase database URL (future upgrade — not used by default SQLite setup)
DATABASE_URL=
