# ─── Market Pulse & Pedagogy — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values for local development.
# Railway injects environment variables directly — no .env file needed in prod.

# ─── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key — required for AI features (ELI5, predictions, vectors)
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Cloudflare Integration (optional but recommended for production) ─────────

# Cloudflare Account ID — found in the Cloudflare dashboard sidebar
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare API Token — needs D1:Edit and Workers AI:Read permissions
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Cloudflare D1 Database ID — found in Workers & Pages > D1 > your database
# Run `node scripts/migrate-to-d1.js` after setting this to initialize the schema
CLOUDFLARE_D1_DB_ID=your_d1_database_id

# ─── Database ─────────────────────────────────────────────────────────────────

# Path to the local SQLite database file (default: ./market_pulse.db)
# For Railway persistent volumes, set this to /data/market_pulse.db
# DATABASE_PATH=/data/market_pulse.db

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Enable/disable rate limiting (default: true)
# Set to 'false' for local development if you want unrestricted API access
RATE_LIMIT_ENABLED=true

# Enable/disable HTTP cache headers (default: true)
# Set to 'false' to disable Cache-Control headers (useful for debugging)
CACHE_ENABLED=true

# Enable/disable WebSocket server for real-time price updates (default: true)
# Set to 'false' to fall back to HTTP polling only
WEBSOCKET_ENABLED=true

# ─── Server ───────────────────────────────────────────────────────────────────

# Port to listen on (default: 3000; Railway sets this automatically)
# PORT=3000

# Node environment (set to 'production' in Railway automatically)
# NODE_ENV=development
