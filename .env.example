# Market Pulse & Pedagogy — Environment Variables
# Copy this file to .env for local development.
# On Railway: set these in the service's "Variables" tab.
# On Cloudflare: use `wrangler secret put SECRET_NAME` for secrets.

# ─── Gemini AI ────────────────────────────────────────────────────────────────

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
# Used by: /api/eli5, /api/predict, /api/vectors, scrub tone classification
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Authentication ───────────────────────────────────────────────────────────

# Secret used to sign JWT access tokens — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here

# Exposed to the Vite client bundle for the Google OAuth redirect
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# ─── Cloudflare ───────────────────────────────────────────────────────────────

# Cloudflare account ID — found at dash.cloudflare.com (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Cloudflare API token — create at dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# D1 database ID — shown after running: wrangler d1 create market-pulse-d1
CLOUDFLARE_D1_DB_ID=your_d1_database_id_here

# ─── Local development (Railway / Express) ────────────────────────────────────

# Server port (Railway sets this automatically)
PORT=3000

# Custom SQLite database path (default: ./market_pulse.db next to package.json)
# On Railway with a volume: DATABASE_PATH=/data/market_pulse.db
DATABASE_PATH=

# API target for Vite dev proxy (defaults to http://localhost:5000)
# Set to http://localhost:8787 when running `npm run wrangler:dev`
VITE_API_TARGET=http://localhost:5000
